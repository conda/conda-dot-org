#!/usr/bin/env python

import sys
from pathlib import Path


errored = []
for path in sys.argv[1:]:
    text = Path(path).read_text()
    if "unsplash.com" in text and "image_credit:" not in text:
        errored.append(path)

if errored:
    print("Use `image_credit` to give proper attribution to external images.")
    print("Affected posts:")
    print(*errored, sep="\n")
    sys.exit(1)
